# Database - Supabase Postgres
DATABASE_URL="postgresql://your-supabase-url"
DIRECT_URL="postgresql://your-supabase-direct-url"

# NextAuth - generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# AI Provider (required for AI features)
ANTHROPIC_API_KEY="sk-ant-..."

# Optional AI providers
OPENAI_API_KEY=""

# Google Vertex AI via Vercel OIDC, no Gemini API key required
GEMINI_MODEL="gemini-2.5-flash"
VERTEX_GEMINI_IMAGE_MODEL="gemini-2.5-flash-image"
GCP_PROJECT_ID=""
GCP_PROJECT_NUMBER=""
GCP_SERVICE_ACCOUNT_EMAIL=""
GCP_WORKLOAD_IDENTITY_POOL_ID=""
GCP_WORKLOAD_IDENTITY_POOL_PROVIDER_ID=""
GCP_LOCATION="us-central1"

# WordPress (optional - for auto-publish)
WP_ENCRYPTION_KEY="your-encryption-key-here"

# Google Tag Manager — JAWIS SEO platform-level analytics
# Add your own GTM container ID here (e.g. GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=""

# Per-project GTM is set in Project Settings UI, not here
