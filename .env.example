# Database - Supabase Postgres
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?schema=plans_seo_pipeline&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?schema=plans_seo_pipeline"

# NextAuth - generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# AI Provider (required for AI features)
ANTHROPIC_API_KEY="sk-ant-..."

# Optional AI providers
OPENAI_API_KEY=""

# Google Vertex AI via Vercel OIDC, no Gemini API key required
GEMINI_MODEL="gemini-2.5-flash"
VERTEX_GEMINI_IMAGE_MODEL="gemini-2.5-flash-image"
GCP_PROJECT_ID=""
GCP_PROJECT_NUMBER=""
GCP_SERVICE_ACCOUNT_EMAIL=""
GCP_WORKLOAD_IDENTITY_POOL_ID=""
GCP_WORKLOAD_IDENTITY_POOL_PROVIDER_ID=""
GCP_LOCATION="us-central1"

# Optional: use a separate OIDC service account/project for GSC + GA4.
# If unset, GSC/GA4 falls back to the GCP_* OIDC config above.
GOOGLE_OIDC_PROJECT_ID=""
GOOGLE_OIDC_PROJECT_NUMBER=""
GOOGLE_OIDC_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_OIDC_WORKLOAD_IDENTITY_POOL_ID=""
GOOGLE_OIDC_WORKLOAD_IDENTITY_POOL_PROVIDER_ID=""

# WordPress (optional - for auto-publish)
WP_ENCRYPTION_KEY="your-encryption-key-here"

# Google Tag Manager — JAWIS SEO platform-level analytics
# Add your own GTM container ID here (e.g. GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=""

# Per-project GTM is set in Project Settings UI, not here
