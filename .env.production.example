# ── Database (Supabase Postgres) ────────────────────────────────────────────
# Get these from Supabase → Project Settings → Database → Connection string.
# Use the pooled connection string for Vercel/serverless runtime connections.
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Use the direct connection string for Prisma schema pushes/migrations.
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-new-secret-here"
# Your Vercel deployment URL (no trailing slash)
NEXTAUTH_URL="https://your-app.vercel.app"

# ── AI APIs (optional — features work in mock mode without these) ────────────
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
VERTEX_GEMINI_IMAGE_MODEL="gemini-2.5-flash-image"

# ── Google Vertex AI via Vercel OIDC ─────────────────────────────────────────
GCP_PROJECT_ID=""
GCP_PROJECT_NUMBER=""
GCP_SERVICE_ACCOUNT_EMAIL=""
GCP_WORKLOAD_IDENTITY_POOL_ID=""
GCP_WORKLOAD_IDENTITY_POOL_PROVIDER_ID=""
GCP_LOCATION="us-central1"

# ── WordPress Encryption ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
WP_ENCRYPTION_KEY="generate-a-random-hex-key-here"

# ── Google integrations (optional unless using GSC/GA4 reports) ─────────────
# Single-line JSON from credentials/service-account.json.
GOOGLE_SERVICE_ACCOUNT_JSON=""

# ── Optional integrations ────────────────────────────────────────────────────
DATAFORSEO_LOGIN=""
DATAFORSEO_PASSWORD=""
PAGESPEED_API_KEY=""
NEXT_PUBLIC_GTM_ID=""
ASANA_WEBHOOK_SECRET=""
ASANA_ACCESS_TOKEN=""
SLACK_SIGNING_SECRET=""
