# ── Database (Supabase Postgres) ────────────────────────────────────────────
# Get these from Supabase → Project Settings → Database → Connection string.
# Use the pooled connection string for Vercel/serverless runtime connections.
# Prisma needs pgbouncer=true with Supabase transaction pooler to avoid prepared statement collisions.
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?schema=plans_seo_pipeline&pgbouncer=true&connection_limit=1"
# Use the direct connection string for Prisma schema pushes/migrations.
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?schema=plans_seo_pipeline"

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-new-secret-here"
# Your Vercel deployment URL (no trailing slash)
NEXTAUTH_URL="https://your-app.vercel.app"

# ── AI APIs (optional — features work in mock mode without these) ────────────
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GEMINI_MODEL="gemini-3-flash-preview"
VERTEX_GEMINI_IMAGE_MODEL="gemini-3.1-flash-image"
# Used as Vertex/Gemini request label for usage tracking. Defaults to "maros" in code.
GEMINI_USAGE_PROJECT_LABEL="maros"

# ── Google Vertex AI via Vercel OIDC ─────────────────────────────────────────
GCP_PROJECT_ID=""
GCP_PROJECT_NUMBER=""
GCP_SERVICE_ACCOUNT_EMAIL=""
GCP_WORKLOAD_IDENTITY_POOL_ID=""
GCP_WORKLOAD_IDENTITY_POOL_PROVIDER_ID=""
# Optional override. If empty, code derives:
# https://iam.googleapis.com/projects/PROJECT_NUMBER/locations/global/workloadIdentityPools/POOL_ID/providers/PROVIDER_ID
GCP_AUDIENCE=""
GCP_LOCATION="global"

# ── Google integrations (GSC/GA4) via Vercel OIDC ───────────────────────────
# Optional separate OIDC config for GSC/GA4. If empty, code falls back to GCP_* above.
GOOGLE_OIDC_PROJECT_ID=""
GOOGLE_OIDC_PROJECT_NUMBER=""
GOOGLE_OIDC_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_OIDC_WORKLOAD_IDENTITY_POOL_ID=""
GOOGLE_OIDC_WORKLOAD_IDENTITY_POOL_PROVIDER_ID=""
GOOGLE_OIDC_AUDIENCE=""

# ── WordPress Encryption ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
WP_ENCRYPTION_KEY="generate-a-random-hex-key-here"

# ── Optional integrations ────────────────────────────────────────────────────
DATAFORSEO_LOGIN=""
DATAFORSEO_PASSWORD=""
PAGESPEED_API_KEY=""
NEXT_PUBLIC_GTM_ID=""
ASANA_WEBHOOK_SECRET=""
ASANA_ACCESS_TOKEN=""
SLACK_SIGNING_SECRET=""
